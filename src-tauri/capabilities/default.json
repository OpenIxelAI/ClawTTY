{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for ClawTTY desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "python3",
          "cmd": "python3",
          "args": ["python/sidecar.py"]
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "python3",
          "cmd": "python3",
          "args": ["python/sidecar.py"]
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open",
    "dialog:allow-save"
  ]
}
